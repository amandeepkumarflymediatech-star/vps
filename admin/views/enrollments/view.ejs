<%- include('../layouts/header') %> <%- include('../layouts/sidebar') %>

<main
  class="bg-gray-100 min-h-screen px-3 sm:px-4 md:px-6 py-6 w-full md:ml-64 transition-all duration-300"
>
  <div class="w-full max-w-4xl mx-auto">
    <!-- ================= MOBILE HEADER ================= -->
    <div class="flex items-center justify-between mb-6 md:hidden">
      <button
        id="menuBtn"
        class="bg-gradient-to-br from-blue-600 via-indigo-600 to-purple-600 text-white px-3 py-2 rounded-lg shadow text-xl"
      >
        ☰
      </button>

      <h1 class="text-lg font-semibold text-gray-800">Enrollment Details</h1>

      <span
        class="bg-gray-200 text-gray-700 px-3 py-2 rounded-lg text-sm font-semibold"
      >
        Admin
      </span>
    </div>

    <!-- ================= DESKTOP HEADER ================= -->
    <div class="hidden md:flex items-center justify-between mb-6">
      <div class="flex items-center gap-4">
        <a
          href="/admin/enrollments"
          class="bg-white p-2 rounded-lg shadow border hover:bg-gray-50 transition"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="h-5 w-5 text-gray-600"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="10 19l-7-7m0 0l7-7m-7 7h18"
            />
          </svg>
        </a>
        <h1 class="text-2xl font-semibold text-gray-800">Enrollment Details</h1>
      </div>
      <span
        class="px-3 py-1 rounded-full text-xs font-bold uppercase <%= enrollment.status === 'COMPLETED' ? 'bg-green-100 text-green-700' : enrollment.status === 'CANCELLED' ? 'bg-red-100 text-red-700' : 'bg-blue-100 text-blue-700' %>"
      >
        <%= enrollment.status %>
      </span>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      <!-- ================= LEFT: DETAILS ================= -->
      <div class="md:col-span-2 space-y-6">
        <!-- Student & Tutor Info -->
        <div class="bg-white rounded-xl shadow border p-6">
          <h2 class="text-lg font-bold text-gray-800 mb-4 border-b pb-2">
            Class Information
          </h2>

          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div>
              <p class="text-xs text-gray-400 uppercase font-bold">Student</p>
              <p class="font-medium text-gray-800">
                <%= enrollment.userId ? enrollment.userId.name : '-' %>
              </p>
              <p class="text-sm text-gray-500">
                <%= enrollment.userId ? enrollment.userId.email : '-' %>
              </p>
            </div>
            <div>
              <p class="text-xs text-gray-400 uppercase font-bold">Tutor</p>
              <p class="font-medium text-gray-800">
                <%= enrollment.tutorId ? enrollment.tutorId.name : '-' %>
              </p>
              <p class="text-sm text-gray-500">
                <%= enrollment.tutorId ? enrollment.tutorId.email : '-' %>
              </p>
            </div>
            <div class="mt-2">
              <p class="text-xs text-gray-400 uppercase font-bold">Date</p>
              <p class="font-medium">
                <%= new Date(enrollment.slot.date).toDateString() %>
              </p>
            </div>
            <div class="mt-2">
              <p class="text-xs text-gray-400 uppercase font-bold">Time Slot</p>
              <p class="font-medium">
                <%= enrollment.slot.startTime %> - <%= enrollment.slot.endTime || '' %>
              </p>
            </div>
          </div>
        </div>

        <!-- Meeting Link & Notes -->
        <div class="bg-white rounded-xl shadow border p-6">
          <h2 class="text-lg font-bold text-gray-800 mb-4 border-b pb-2">
            Links & Notes
          </h2>
          <div class="space-y-4">
            <div>
              <label class="block text-xs text-gray-400 uppercase font-bold mb-1">
                Meeting Link
              </label>
              <div class="flex gap-2">
                <input
                  type="text"
                  id="meetingLink"
                  value="<%= enrollment.meetingLink || '' %>"
                  placeholder="https://zoom.us/j/..."
                  class="flex-1 bg-gray-50 border rounded-lg px-3 py-2 text-sm outline-none focus:ring-2 focus:ring-blue-500"
                />
                <% if (enrollment.meetingLink) { %>
                <a
                  href="<%= enrollment.meetingLink %>"
                  target="_blank"
                  class="bg-blue-600 text-white px-3 py-2 rounded-lg text-sm font-medium hover:bg-blue-700"
                >
                  Join
                </a>
                <% } %>
              </div>
            </div>

            <div>
              <label class="block text-xs text-gray-400 uppercase font-bold mb-1">
                Admin Notes
              </label>
              <textarea
                id="notes"
                rows="3"
                placeholder="Add private notes here..."
                class="w-full bg-gray-50 border rounded-lg px-3 py-2 text-sm outline-none focus:ring-2 focus:ring-blue-500"
              ><%= enrollment.notes || '' %></textarea>
            </div>
          </div>
        </div>
      </div>

      <!-- ================= RIGHT: STATUS UPDATE ================= -->
      <div class="space-y-6">
        <div class="bg-white rounded-xl shadow border p-6">
          <h2 class="text-lg font-bold text-gray-800 mb-4 border-b pb-2">
            Update Status
          </h2>

          <div class="space-y-4">
            <select
              id="statusSelect"
              class="w-full bg-gray-50 border rounded-lg px-3 py-2 text-sm outline-none focus:ring-2 focus:ring-blue-500"
            >
              <option value="UPCOMING" <%= enrollment.status === 'UPCOMING' ? 'selected' : '' %>>Upcoming</option>
              <option value="COMPLETED" <%= enrollment.status === 'COMPLETED' ? 'selected' : '' %>>Completed</option>
              <option value="CANCELLED" <%= enrollment.status === 'CANCELLED' ? 'selected' : '' %>>Cancelled</option>
              <option value="MISSED" <%= enrollment.status === 'MISSED' ? 'selected' : '' %>>Missed</option>
            </select>

            <button
              id="updateBtn"
              class="w-full bg-gradient-to-r from-blue-600 to-indigo-600 text-white py-2 rounded-lg font-bold shadow hover:shadow-lg transition-all"
            >
              Save Changes
            </button>
          </div>
        </div>

        <div class="bg-blue-50 border-l-4 border-blue-500 p-4 rounded-r-xl">
          <p class="text-xs text-blue-800 font-medium">
            Updating the status or meeting link will reflect on the student's dashboard immediately.
          </p>
        </div>
      </div>
    </div>
  </div>
</main>

<!-- ================= SCRIPTS ================= -->
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script>
  const updateBtn = document.getElementById("updateBtn");
  
  updateBtn.addEventListener("click", async () => {
    const status = document.getElementById("statusSelect").value;
    const meetingLink = document.getElementById("meetingLink").value;
    const notes = document.getElementById("notes").value;

    try {
      updateBtn.disabled = true;
      updateBtn.innerText = "Saving...";

      const res = await fetch("/admin/enrollments/<%= enrollment._id %>/update", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ status, meetingLink, notes }),
      });

      const data = await res.json();

      if (data.success) {
        Swal.fire({
          icon: 'success',
          title: 'Updated!',
          text: 'Enrollment details updated successfully.',
          timer: 1500,
          showConfirmButton: false
        }).then(() => {
          window.location.reload();
        });
      } else {
        throw new Error(data.message || "Update failed");
      }
    } catch (err) {
      console.error(err);
      Swal.fire({
        icon: 'error',
        title: 'Oops...',
        text: err.message,
      });
    } finally {
      updateBtn.disabled = false;
      updateBtn.innerText = "Save Changes";
    }
  });
</script>

<%- include('../layouts/footer') %>
