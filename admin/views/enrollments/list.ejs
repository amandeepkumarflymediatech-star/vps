<%- include('../layouts/header') %> <%- include('../layouts/sidebar') %>

<main
  class="bg-gray-100 min-h-screen px-3 sm:px-4 md:px-6 py-6 w-full md:ml-64 transition-all duration-300"
>
  <div class="w-full max-w-6xl mx-auto">
    <!-- ================= MOBILE HEADER ================= -->
    <div class="flex items-center justify-between mb-6 md:hidden">
      <button
        id="menuBtn"
        class="bg-gradient-to-br from-blue-600 via-indigo-600 to-purple-600 text-white px-3 py-2 rounded-lg shadow text-xl"
      >
        ☰
      </button>

      <h1 class="text-lg font-semibold text-gray-800">Enrollments</h1>

      <span
        class="bg-gray-200 text-gray-700 px-3 py-2 rounded-lg text-sm font-semibold"
      >
        Admin
      </span>
    </div>

    <!-- ================= DESKTOP HEADER ================= -->
    <div class="hidden md:flex items-center justify-between mb-6">
      <h1 class="text-2xl font-semibold text-gray-800">Enrollments</h1>
    </div>

    <!-- ================= ENROLLMENTS TABLE (DESKTOP) ================= -->
    <div class="hidden md:block bg-white rounded-xl shadow border overflow-x-auto">
      <table class="min-w-full text-sm text-left">
        <thead class="bg-gray-50 text-gray-600 uppercase text-xs">
          <tr>
            <th class="px-4 py-3">Student</th>
            <th class="px-4 py-3">Tutor</th>
            <th class="px-4 py-3">Date</th>
            <th class="px-4 py-3">Time</th>
            <th class="px-4 py-3">Status</th>
            <th class="px-4 py-3 text-right">Action</th>
          </tr>
        </thead>

        <tbody class="divide-y">
          <% if (!enrollments || !enrollments.length) { %>
          <tr>
            <td colspan="6" class="px-4 py-8 text-center text-gray-400">
              No enrollments found
            </td>
          </tr>
          <% } %> <% enrollments.forEach(e => { %>
          <tr class="hover:bg-gray-50">
            <td class="px-4 py-3 font-medium text-gray-800">
              <%= e.userId ? e.userId.name : '-' %>
              <div class="text-[10px] text-gray-400"><%= e.userId ? e.userId.email : '' %></div>
            </td>

            <td class="px-4 py-3">
              <%= e.tutorId ? e.tutorId.name : '-' %>
            </td>

            <td class="px-4 py-3">
              <%= new Date(e.slot.date).toLocaleDateString() %>
            </td>

            <td class="px-4 py-3 text-xs text-gray-500">
              <%= e.slot.startTime %> - <%= e.slot.endTime || '' %>
            </td>

            <td class="px-4 py-3">
              <span
                class="px-2 py-1 rounded-full text-[10px] font-bold uppercase <%= e.status === 'COMPLETED' ? 'bg-green-100 text-green-700' : e.status === 'CANCELLED' ? 'bg-red-100 text-red-700' : 'bg-blue-100 text-blue-700' %>"
              >
                <%= e.status %>
              </span>
            </td>

            <td class="px-4 py-3 text-right">
              <a
                href="/admin/enrollments/<%= e._id %>"
                class="text-blue-600 hover:underline text-sm font-medium"
              >
                View
              </a>
            </td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>

    <!-- ================= ENROLLMENTS CARDS (MOBILE) ================= -->
    <div class="md:hidden space-y-4">
      <% if (!enrollments || !enrollments.length) { %>
        <div class="bg-white rounded-xl border p-8 text-center text-gray-400">
          No enrollments found
        </div>
      <% } else { %>
        <% enrollments.forEach(e => { %>
          <div class="bg-white rounded-xl shadow border p-4 space-y-3">
            <div class="flex justify-between items-start">
              <div>
                <p class="font-bold text-gray-800"><%= e.userId ? e.userId.name : '-' %></p>
                <div class="text-[10px] text-gray-500"><%= e.userId ? e.userId.email : '' %></div>
              </div>
              <span
                class="px-2 py-1 rounded-full text-[10px] font-bold uppercase <%= e.status === 'COMPLETED' ? 'bg-green-100 text-green-700' : e.status === 'CANCELLED' ? 'bg-red-100 text-red-700' : 'bg-blue-100 text-blue-700' %>"
              >
                <%= e.status %>
              </span>
            </div>
            
            <div class="grid grid-cols-2 gap-2 text-xs">
              <div>
                <p class="text-gray-400 font-bold uppercase text-[9px]">Tutor</p>
                <p><%= e.tutorId ? e.tutorId.name : '-' %></p>
              </div>
              <div>
                <p class="text-gray-400 font-bold uppercase text-[9px]">Date</p>
                <p><%= new Date(e.slot.date).toLocaleDateString() %></p>
              </div>
              <div class="col-span-2">
                <p class="text-gray-400 font-bold uppercase text-[9px]">Time</p>
                <p><%= e.slot.startTime %> - <%= e.slot.endTime || '' %></p>
              </div>
            </div>

            <a
              href="/admin/enrollments/<%= e._id %>"
              class="block w-full text-center bg-gray-50 hover:bg-gray-100 text-blue-600 py-2 rounded-lg text-sm font-medium border"
            >
              View Details
            </a>
          </div>
        <% }) %>
      <% } %>
    </div>

    <!-- ================= PAGINATION ================= -->
    <% if (totalPages > 1) { %>
    <div class="flex items-center justify-between mt-6">
      <p class="text-sm text-gray-600">
        Page <span class="font-semibold"><%= currentPage %></span> of
        <span class="font-semibold"><%= totalPages %></span>
      </p>

      <div class="flex items-center gap-2">
        <a
          href="?page=<%= currentPage - 1 %>"
          class="px-3 py-2 rounded-lg border text-sm font-medium <%= currentPage === 1 ? 'pointer-events-none opacity-50 bg-gray-100' : 'hover:bg-gray-100' %>"
        >
          Prev
        </a>

        <% for (let i = 1; i <= totalPages; i++) { %>
        <a
          href="?page=<%= i %>"
          class="px-3 py-2 rounded-lg text-sm font-medium border <%= i === currentPage ? 'bg-blue-600 text-white border-blue-600' : 'hover:bg-gray-100' %>"
        >
          <%= i %>
        </a>
        <% } %>

        <a
          href="?page=<%= currentPage + 1 %>"
          class="px-3 py-2 rounded-lg border text-sm font-medium <%= currentPage === totalPages ? 'pointer-events-none opacity-50 bg-gray-100' : 'hover:bg-gray-100' %>"
        >
          Next
        </a>
      </div>
    </div>
    <% } %>
  </div>
</main>

<%- include('../layouts/footer') %>
