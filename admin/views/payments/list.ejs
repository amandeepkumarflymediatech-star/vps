<%- include('../layouts/header') %> <%- include('../layouts/sidebar') %>

<main
  class="bg-gray-100 min-h-screen px-3 sm:px-4 md:px-6 py-6 w-full md:ml-64 transition-all duration-300"
>
  <div class="w-full max-w-6xl mx-auto">
    <!-- ================= MOBILE HEADER ================= -->
    <div class="flex items-center justify-between mb-6 md:hidden">
      <button
        id="menuBtn"
        class="bg-gradient-to-br from-blue-600 via-indigo-600 to-purple-600 text-white px-3 py-2 rounded-lg shadow text-xl"
      >
        ☰
      </button>

      <h1 class="text-lg font-semibold text-gray-800">Payments</h1>

      <span
        class="bg-gray-200 text-gray-700 px-3 py-2 rounded-lg text-sm font-semibold"
      >
        Admin
      </span>
    </div>

    <!-- ================= DESKTOP HEADER ================= -->
    <div class="hidden md:flex items-center justify-between mb-6">
      <h1 class="text-2xl font-semibold text-gray-800">Payments</h1>
    </div>

    <!-- ================= FILTER BAR ================= -->
    <div class="flex justify-end mb-4">
      <form action="/admin/payments" method="GET" class="w-full md:w-auto flex items-center">
        <select name="status" class="bg-white border text-gray-700 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 w-full" onchange="this.form.submit()">
          <option value="">All Statuses</option>
          <option value="PENDING" <%= typeof currentStatus !== 'undefined' && currentStatus === 'PENDING' ? 'selected' : '' %>>Pending</option>
          <option value="SUCCESS" <%= typeof currentStatus !== 'undefined' && currentStatus === 'SUCCESS' ? 'selected' : '' %>>Success</option>
          <option value="VERIFIED" <%= typeof currentStatus !== 'undefined' && currentStatus === 'VERIFIED' ? 'selected' : '' %>>Verified</option>
          <option value="REJECTED" <%= typeof currentStatus !== 'undefined' && currentStatus === 'REJECTED' ? 'selected' : '' %>>Rejected</option>
        </select>
      </form>
    </div>

    <!-- ================= PAYMENTS TABLE (DESKTOP) ================= -->
    <div class="hidden md:block bg-white rounded-xl shadow border overflow-x-auto">
      <table class="min-w-full text-sm text-left">
        <thead class="bg-gray-50 text-gray-600 uppercase text-xs">
          <tr>
            <th class="px-4 py-3">User</th>
            <th class="px-4 py-3">Email</th>
            <th class="px-4 py-3">Amount</th>
            <th class="px-4 py-3">Method</th>
            <th class="px-4 py-3">Status</th>
            <th class="px-4 py-3 text-right">Action</th>
          </tr>
        </thead>

        <tbody class="divide-y">
          <% if (!payments || !payments.length) { %>
          <tr>
            <td colspan="5" class="px-4 py-8 text-center text-gray-400">
              No payments found
            </td>
          </tr>
          <% } %> <% payments.forEach(p => { %>
          <tr class="hover:bg-gray-50">
            <td class="px-4 py-3 font-medium text-gray-800">
              <%= p.userId ? p.userId.name : '-' %>
            </td>

            <td class="px-4 py-3"><%= p.userId ? p.userId.email : '-' %></td>

            <td class="px-4 py-3">₹<%= p.amount %></td>
            <td class="px-4 py-3 text-xs font-medium text-gray-500"><%= p.method || 'UPI' %></td>
            <td class="px-4 py-3">
              <span
                class="px-2 py-1 rounded-full text-xs font-semibold <%= p.status === 'VERIFIED' ? 'bg-green-100 text-green-700' : p.status === 'REJECTED' ? 'bg-red-100 text-red-700' : 'bg-yellow-100 text-yellow-700' %>"
              >
                <%= p.status %>
              </span>
            </td>

            <td class="px-4 py-3 text-right">
              <a
                href="/admin/payments/<%= p._id %>"
                class="text-blue-600 hover:underline text-sm font-medium"
              >
                View
              </a>
            </td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>

    <!-- ================= PAYMENTS CARDS (MOBILE) ================= -->
    <div class="md:hidden space-y-4">
      <% if (!payments || !payments.length) { %>
        <div class="bg-white rounded-xl border p-8 text-center text-gray-400">
          No payments found
        </div>
      <% } else { %>
        <% payments.forEach(p => { %>
          <div class="bg-white rounded-xl shadow border p-4 space-y-3">
            <div class="flex justify-between items-start">
              <div>
                <p class="font-bold text-gray-800"><%= p.userId ? p.userId.name : '-' %></p>
                <div class="text-[10px] text-gray-500"><%= p.userId ? p.userId.email : '-' %></div>
              </div>
              <span
                class="px-2 py-1 rounded-full text-[10px] font-bold uppercase <%= p.status === 'SUCCESS' || p.status === 'VERIFIED' ? 'bg-green-100 text-green-700' : p.status === 'REJECTED' ? 'bg-red-100 text-red-700' : 'bg-yellow-100 text-yellow-700' %>"
              >
                <%= p.status %>
              </span>
            </div>
            
            <div class="flex justify-between items-center text-xs">
              <p class="font-bold text-lg text-gray-800">₹<%= p.amount %></p>
              <div class="text-right">
                <p class="text-gray-400 font-bold uppercase text-[9px]">Method</p>
                <p class="bg-gray-100 px-2 py-0.5 rounded inline-block"><%= p.method || 'UPI' %></p>
              </div>
            </div>

            <a
              href="/admin/payments/<%= p._id %>"
              class="block w-full text-center bg-gray-50 hover:bg-gray-100 text-blue-600 py-2 rounded-lg text-sm font-medium border"
            >
              View Details
            </a>
          </div>
        <% }) %>
      <% } %>
    </div>
    <!-- ================= PAGINATION ================= -->
    <div class="flex flex-col sm:flex-row items-center justify-between mt-6 mb-4 gap-4">
      <p class="text-sm text-gray-600 whitespace-nowrap">
        Showing <span class="font-semibold"><%= typeof payments !== 'undefined' && payments.length > 0 ? ((currentPage - 1) * limit) + 1 : 0 %></span> to <span class="font-semibold"><%= ((currentPage - 1) * limit) + (typeof payments !== 'undefined' ? payments.length : 0) %></span> of <span class="font-semibold"><%= typeof totalPayments !== 'undefined' ? totalPayments : 0 %></span> results
      </p>

      <% if (totalPages > 1) { %>
      <div class="flex items-center gap-2 overflow-x-auto pb-2 sm:pb-0">
        <a
          href="?page=<%= currentPage - 1 %><%= typeof currentStatus !== 'undefined' && currentStatus ? '&status=' + currentStatus : '' %>"
          class="px-3 py-2 rounded-lg border text-sm font-medium <%= currentPage === 1 ? 'pointer-events-none opacity-50 bg-gray-100' : 'hover:bg-gray-100' %>"
        >
          Prev
        </a>

        <% 
        let startPage = Math.max(1, currentPage - 2);
        let endPage = Math.min(totalPages, currentPage + 2);
        
        if (startPage > 1) { 
        %>
          <a href="?page=1<%= typeof currentStatus !== 'undefined' && currentStatus ? '&status=' + currentStatus : '' %>" class="px-3 py-2 rounded-lg text-sm font-medium border hover:bg-gray-100">1</a>
          <% if (startPage > 2) { %>
            <span class="px-2 py-2 text-gray-400">...</span>
          <% } %>
        <% } %>

        <% for (let i = startPage; i <= endPage; i++) { %>
        <a
          href="?page=<%= i %><%= typeof currentStatus !== 'undefined' && currentStatus ? '&status=' + currentStatus : '' %>"
          class="px-3 py-2 rounded-lg text-sm font-medium border <%= i === currentPage ? 'bg-blue-600 text-white border-blue-600' : 'hover:bg-gray-100' %>"
        >
          <%= i %>
        </a>
        <% } %>

        <% if (endPage < totalPages) { %>
          <% if (endPage < totalPages - 1) { %>
            <span class="px-2 py-2 text-gray-400">...</span>
          <% } %>
          <a href="?page=<%= totalPages %><%= typeof currentStatus !== 'undefined' && currentStatus ? '&status=' + currentStatus : '' %>" class="px-3 py-2 rounded-lg text-sm font-medium border hover:bg-gray-100"><%= totalPages %></a>
        <% } %>

        <a
          href="?page=<%= currentPage + 1 %><%= typeof currentStatus !== 'undefined' && currentStatus ? '&status=' + currentStatus : '' %>"
          class="px-3 py-2 rounded-lg border text-sm font-medium <%= currentPage === totalPages ? 'pointer-events-none opacity-50 bg-gray-100' : 'hover:bg-gray-100' %>"
        >
          Next
        </a>
      </div>
      <% } %>
    </div>
  </div>
</main>


<%- include('../layouts/footer') %>
